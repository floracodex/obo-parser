{
  "name": "obo-parser",
  "version": "0.1.0",
  "description": "A spec-complete OBO 1.4 format parser for TypeScript/JavaScript with streaming and string APIs",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "obo",
    "ontology",
    "parser",
    "bioinformatics",
    "obo-format",
    "plant-ontology",
    "gene-ontology",
    "obo-foundry"
  ],
  "author": "FloraCodex",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floracodex/obo-parser.git"
  },
  "bugs": {
    "url": "https://github.com/floracodex/obo-parser/issues"
  },
  "homepage": "https://github.com/floracodex/obo-parser#readme",
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
