{
  "name": "@floracodex/obo-parser",
  "version": "1.0.1",
  "description": "A spec-complete OBO 1.4 format parser for TypeScript/JavaScript with streaming and string APIs",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "obo",
    "ontology",
    "parser",
    "bioinformatics",
    "obo-format",
    "plant-ontology",
    "gene-ontology",
    "obo-foundry"
  ],
  "author": "Flora Codex, LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floracodex/obo-parser.git"
  },
  "bugs": {
    "url": "https://github.com/floracodex/obo-parser/issues"
  },
  "homepage": "https://github.com/floracodex/obo-parser#readme",
  "devDependencies": {
    "@floracodex/eslint-config": "^1.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
